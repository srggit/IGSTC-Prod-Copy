<script>
   // CKEDITOR.replace('comment');
    // function isValidEmail(email) {
    //     return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    // }

    

    function submitCase() {
        var program = document.getElementById('program').value.trim();

         var allowedPrograms = [
            '2+2 Call',
            'Industrial Fellowships',
            'PECFAR',
            'Workshop',
            'SING',
            'WISER'
        ];

        // if (!allowedPrograms.includes(program)) {
        //     showMessage('Please select a Program.', 'error');
        //     document.getElementById('program').focus();
        //     return;
        // }
        var payload = {
            name: document.getElementById('name').value.trim(),
            email: document.getElementById('email').value.trim(),
          //  comment: CKEDITOR.instances.comment.getData(),
            comment:document.getElementById('comment').value.trim(),
            proposalId: document.getElementById('proposalId').value.trim(),
            program: program
           // program: document.getElementById('program').value
        };

        if (!payload.name || !payload.email || !payload.comment) {
            showMessage('Please fill all mandatory fields.', 'error');
            return;
        }
        

         // ✅ Email format validation
        // if (!isValidEmail(payload.email)) {
        //     showMessage('Please enter a valid email address.', 'error');
        //     return;
        // }
       

       
        toggleLoading(true);

        // SEND DATA TO PARENT PAGE
        window.parent.postMessage({
            type: 'IGSTC_SUPPORT_SUBMIT',
            data: payload
        }, '*');
    }
    

    window.addEventListener('message', function(event) {
            if (!event.data || event.data.type !== 'IGSTC_SUPPORT_RESPONSE') return;

            toggleLoading(false);

            if (event.data.success) {
                // Notify parent to close modal + show toast
                window.parent.postMessage({
                    type: 'IGSTC_SUPPORT_SUCCESS'
                }, '*');

                resetForm();
            } else {
                // Still show error inside iframe
                showMessage(event.data.message, 'error');
            }
        });

    function toggleLoading(isLoading) {
        document.getElementById('spinner').style.display = isLoading ? 'block' : 'none';
        document.getElementById('submitBtn').disabled = isLoading;
    }

    function showMessage(msg, type) {
        var el = document.getElementById('message');
        el.innerHTML = msg;
        el.className = 'message ' + type;
    }

    function resetForm() {
        document.getElementById('name').value = '';
        document.getElementById('email').value = '';
        document.getElementById('proposalId').value = '';
        document.getElementById('comment').value = '';
        document.getElementById('program').value = '';
        //CKEDITOR.instances.comment.setData('');
    }

    

    function clearErrorOnProgramChange() {
        var msgEl = document.getElementById('message');
        var programEl = document.getElementById('program');

        // Clear message text + styles
        if (msgEl) {
            msgEl.innerHTML = '';
            msgEl.className = 'message';
        }

        // Remove red border if added earlier
        if (programEl) {
            programEl.style.border = '';
        }
    }

    function clearErrorOnInputChange() {
        var msgEl = document.getElementById('message');

        if (msgEl) {
            msgEl.innerHTML = '';
            msgEl.className = 'message';
        }

        // Remove red border from all fields
        var fields = document.querySelectorAll(
            '#name, #email, #comment'
        );

        fields.forEach(function(el) {
            el.style.border = '';
        });
    }


</script>

</apex:page>