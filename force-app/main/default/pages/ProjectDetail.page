                                                        <div class="text-muted small mt-1"
                                                            ng-if="(wp.AccountList | filter:{selected:true}).length === 0">
                                                            No partners selected
                                                        </div>

                                                    </div>
                                                </td>

                                                <td>
                                                    <input type="number" class="form-control" ng-model="wp.wpStartMonth"
                                                        ng-disabled="proposalStage || !isCoordinator"
                                                        ng-change="validateWorkPackageMonths(wp)"
