                                                                ng-repeat="partner in wp.AccountList | filter:{selected:true}"
                                                                title="{{partner.Name}}">
                                                                {{partner.Name | limitTo:15}}{{partner.Name.length >
                                                                15 ? '...' : ''}}
                                                            </span>
                                                        </div>

