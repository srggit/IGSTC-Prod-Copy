                                                </td>

                                                <td class="text-center" ng-hide="!isCoordinator">

                                                    <i class="fa-solid fa-circle-xmark remove-deliverable"
                                                        ng-click="removeDeliverable($parent.$index,$index)"
                                                        style="color: red;"></i>

                                                </td>

                                            </tr>

                                        </tbody>

                                    </table>

                                </div>

                            </div>
