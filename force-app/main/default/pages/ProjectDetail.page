                                                    <small class="text-danger" ng-if="wp.endMonthStartError">
                                                        Must be &gt;= {{wp.wpStartMonth}}
                                                    </small>
                                                    <small class="text-danger" ng-if="wp.endMonthMaxDurationError">
                                                        Must be &lt;= {{maxDurations}}
                                                    </small>
                                                </td>

                                                <!-- Add Deliverable Button -->
                                                <td class="text-center" ng-hide="!isCoordinator">

                                                    <button class="add-deliverable-btn"
