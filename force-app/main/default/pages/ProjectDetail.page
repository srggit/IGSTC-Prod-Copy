        <apex:stylesheet value="{!$Resource.ApplicantPortalCSS}" />
        <style>
            /* Full page spinner styles */
            .page-spinner-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(255, 255, 255, 0.9);
                display: flex;
                justify-content: center;
                align-items: center;
                z-index: 9999;
            }
            
            .page-spinner {
                width: 50px;
                height: 50px;
                border: 5px solid #f3f3f3;
                border-top: 5px solid #0070d2;
                border-radius: 50%;
                animation: spin 1s linear infinite;
            }
            
            .page-spinner-text {
                margin-left: 15px;
                font-size: 16px;
                color: #0070d2;
                font-weight: 500;
            }
            
            @keyframes spin {
                0% { transform: rotate(0deg); }
                100% { transform: rotate(360deg); }
            }
            
            .no-border-right {
                border-right: none !important;
            }

            .hide-coordinator-column th:last-child,
            .hide-coordinator-column td:last-child {
                border-right: none !important;
            }

            /* SAFE VERSION - Only target Gantt chart elements, no global reset */
            #ganttChart .gantt-container {
                border: 1px solid #d8dde6;
                overflow-x: auto;
                position: relative;
                background: white;
                display: inline-block;
                min-width: 100%;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            }

            #ganttChart .month-row {
                display: grid;
                background: #f3f3f3;
                border-bottom: 2px solid #d8dde6;
                position: relative;
                z-index: 3;
                width: 100%;
                margin: 0;
                padding: 0;
            }

            #ganttChart .month {
                border-right: 1px solid #e5e5e5;
                text-align: center;
                font-size: 12px;
                padding: 6px 0;
                white-space: nowrap;
                margin: 0;
                line-height: normal;
            }

            #ganttChart .content-area {
                position: relative;
                width: 100%;
            }

            /* Vertical lines overlay */
            #ganttChart .vertical-lines-overlay {
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                display: grid;
                pointer-events: none;
                z-index: 1;
                width: 100%;
            }

            #ganttChart .vertical-line {
                border-right: 1px solid rgba(0, 0, 0, 0.15);
                /* Slightly darker lines */
                height: 100%;
                margin: 0;
                padding: 0;
            }

            #ganttChart .wp-block {
                margin-bottom: 6px;
                position: relative;
                z-index: 2;
                width: 100%;
            }

            /* Row background - transparent to show lines */
            #ganttChart .row {
                display: grid;
                align-items: center;
                height: 40px;
                border-bottom: 1px solid #dfdfdf;
                position: relative;
                z-index: 2;
                background: transparent;
                width: 100%;
                margin: 0;
                padding: 0;
            }

            /* CRITICAL FIX: WP wrapper should not have background */
            #ganttChart .wp-wrapper {
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                position: relative;
                z-index: 2;
                min-width: 0;
                width: 100%;
                height: 100%;
                margin: 0;
                padding: 0;
                background: transparent;
                /* Ensure transparent */
            }

            /* WP title - keep background for readability */
            #ganttChart .wp-title {
                font-size: 12px;
                font-weight: 600;
                color: #2c3e50;
                margin-bottom: 3px;
                display: flex;
                align-items: center;
                gap: 6px;
                flex-wrap: nowrap;
                position: relative;
                z-index: 3;
                /*background-color: rgba(255, 255, 255, 0.9);*/
                padding: 2px 4px;
                border-radius: 2px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                width: 100%;
                line-height: normal;
                margin-top: 5px;
            }

            /* CRITICAL FIX: WP bar should be semi-transparent to show lines through it */
            #ganttChart .wp-bar {
                /* background: rgba(30, 235, 68, 0.7); */
                /* 70% opacity green - lets lines show through */
                /* background: rgb(0, 231, 0); */
                background: #2ea043;
                height: 8px;
                border-radius: 3px;
                width: 100%;
                position: relative;
                z-index: 2;
                margin: 0;
                padding: 0;
            }

            /* Deliverable row */
            #ganttChart .deliverable-row {
                height: 40px;
                position: relative;
                z-index: 2;
                background: transparent;
                margin: 0;
                padding: 0;
            }

            /* Deliverable bar - keep opaque for better visibility */
            #ganttChart .deliverable-bar {
                height: 26px;
                border-radius: 4px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 12px;
                font-weight: 500;
                position: relative;
                z-index: 2;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                padding: 0;
                margin: 0;
                width: 100%;
                box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
                box-sizing: border-box;
                /* Keep opaque for deliverables */
            }

            #ganttChart .deliverable-bar span {
                padding-left: 8px;
                padding-right: 8px;
                display: inline-block;
                max-width: 100%;
                overflow: hidden;
                text-overflow: ellipsis;
                line-height: normal;
                text-align: center;
                width: 100%;
            }

            #ganttChart .contact-badges-inline {
                display: inline-flex;
                gap: 4px;
                align-items: center;
                flex-shrink: 0;
                margin-left: 6px;
                position: relative;
                z-index: 4;
            }

            #ganttChart .contact-badge {
                background: #0070d2;
                color: white;
                font-size: 10px;
                font-weight: 600;
                padding: 2px 6px;
                border-radius: 12px;
                line-height: 1;
                cursor: default;
                min-width: 20px;
                text-align: center;
                transition: background-color 0.2s ease;
                display: inline-block;
            }

            #ganttChart .contact-badge:hover {
                background: #005fb2;
            }

            /* Override Bootstrap specific styles */
            #ganttChart .row,
            #ganttChart .row>*,
            #ganttChart .wp-block,
            #ganttChart .wp-wrapper,
            #ganttChart .deliverable-bar {
                box-sizing: border-box;
            }

            /* Remove any Bootstrap margins and paddings */
            #ganttChart .row {
                margin-left: 0 !important;
                margin-right: 0 !important;
            }

            /* Ensure proper layering */
            #ganttChart .vertical-lines-overlay {
                z-index: 1;
            }

            #ganttChart .wp-block,
            #ganttChart .row,
            #ganttChart .wp-wrapper,
            #ganttChart .deliverable-bar {
                z-index: 2;
            }

            #ganttChart .wp-title {
                z-index: 3;
            }

            #ganttChart .contact-badges-inline,
            #ganttChart .contact-badge {
                z-index: 4;
            }
        </style>
