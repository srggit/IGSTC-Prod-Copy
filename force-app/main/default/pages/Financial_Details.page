<apex:page sidebar="false" showHeader="false" standardStylesheets="false" controller="WorkshopController2">
    <html>
    <div ng-controller="financialdetails_ctrl">

        <style>
            /* ===== info card ===== */
            .info-card,
            .summary-card,
            .table-card {
                background: #ffffff;
                margin-bottom: 15px;;
                border-radius: 14px;
                padding: 18px;
                box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
                border: 1px solid #eef0f4;
                /* SAME as participant card */
            }

            .info-list li {
                margin-bottom: 10px;
                line-height: 1.5;
            }

            /* ===== accordion ===== */
            .modern-accordion-item {
                border: none;
                background: transparent;
            }

            .modern-accordion-btn {
                background: #ffffff !important;
                box-shadow: none !important;
                border-radius: 12px !important;
                padding: 16px 18px;
                border: 1px solid #eef0f4;
                /* SAME */
            }

            /* ===== inputs already matched ===== */
            .modern-input {
                border-radius: 8px !important;
                border: 1px solid #dfe3eb !important;
            }

            /* ===== table header match ===== */
            .table-modern thead th {
                background: #f5f7fb;
                /* SAME as previous */
                border: none !important;
                font-weight: 600;
            }

            /* ===== table card ===== */
            .table-card {
                background: #ffffff;
                border-radius: 12px;
                padding: 12px;
                box-shadow: 0 4px 14px rgba(0, 0, 0, 0.05);
            }

            /* ===== summary card ===== */
            .summary-card {
                background: #ffffff;
                border-radius: 14px;
                padding: 14px;
                box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
                border: 1px solid #eef0f4;
            }

            .btn-add {
                background: #4c6ef5;
                border: none;
                color: white;
                width: 25px;
                height: 25px;
                border-radius: 50%;
            }

            .btn-remove {
                background: #ffe3e3;
                border: none;
                color: #e03131;
                width: 25px;
                height: 25px;
                border-radius: 50%;
            }
        </style>

        <head>
            <apex:stylesheet value="{!$Resource.ApplicantPortalCSS}" />
            <apex:stylesheet value="{!$Resource.timeLineCss}" />
            <script>
                var userId = '{!$CurrentPage.parameters.id}';
            </script>
        </head>

        <body>

            <div class="container mt-5">
                <div class="row mx-5">
                    <div class="col-md-12">
                        <div class="tab-link" ng-show="proposalStage">
                            <div class="progress">
                                <div class="progress-success w-100"></div>
                            </div>
                            <ul>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Coordinators_Page')">
                                        <div class="icon-circle">
                                            <i class="fab fa-wpforms"></i>
                                        </div>
                                        <span>Co-ordinators Detail</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('BasicDetails_Page')">
                                        <div class="icon-circle">
                                            <i class="fa-regular fa-building-o"></i>
                                        </div>
                                        <span>Basic Details</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Proposal_Details')">
                                        <div class="icon-circle">
                                            <i class="fa-solid fa-address-book"></i>
                                        </div>
                                        <span>Proposal Details</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Participants')">
                                        <div class="icon-circle">
                                            <i class="fas fa-file-invoice"></i>
                                        </div>
                                        <span>Participants</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Financial_Details')">
                                        <div class="icon-circle">
                                            <i class="fas fa-box"></i>
                                        </div>
                                        <span>Budget Details</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Curriculum_vitae')">
                                        <div class="icon-circle">
                                            <i class="fab fa-meetup"></i>
                                        </div>
                                        <span>Curriculum vitae</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Meeting_Theme')">
                                        <div class="icon-circle">
                                            <i class="fas fa-people-group"></i>
                                        </div>
                                        <span>Workshop Agenda</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('SignatureOfCoordinators')">
                                        <div class="icon-circle">
                                            <i class="fas fa-file-signature"></i>
                                        </div>
                                        <span>Signature</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div class="tab-link" ng-hide="proposalStage">
                            <div class="progress">
                                <div class="progress-success wp-6"></div>
                            </div>
                            <ul>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fab fa-wpforms"></i>
                                        </div>
                                        <span>Co-ordinators Detail</span>
                                    </a>
                                </li>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fa-regular fa-building-o"></i>
                                        </div>
                                        <span>Basic Details</span>
                                    </a>
                                </li>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fa-solid fa-address-book"></i>
                                        </div>
                                        <span>Proposal Details</span>
                                    </a>
                                </li>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fas fa-file-invoice"></i>
                                        </div>
                                        <span>Participants</span>
                                    </a>
                                </li>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fas fa-box"></i>
                                        </div>
                                        <span>Budget Details</span>
                                    </a>
                                </li>
                                <li>
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fab fa-meetup"></i>
                                        </div>
                                        <span>Curriculum vitae</span>
                                    </a>
                                </li>
                                <li>
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fas fa-people-group"></i>
                                        </div>
                                        <span>Workshop Agenda</span>
                                    </a>
                                </li>
                                <li>
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fas fa-file-signature"></i>
                                        </div>
                                        <span>Signature</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="row mt-5 mx-5">
                    <div class="col-md-12 alert bg-color-list" role="alert">
                        <ul class="font-if">
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>
                                <b>Travel:</b> International Airfare (Travel from home to Venue and back / incl. Visa
                                and medical
                                insurance), Domestic Travel, Local Transport
                            </li>
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>
                                <b>Accommodation:</b> Hotel / Guest House (incl. breakfast)
                            </li>
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>
                                <b>Catering:</b> Official Dinner (only one), Day rate for the meeting (lunch buffet /
                                coffee
                                break)
                            </li>
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>
                                <b>Other:</b> Printing, Technical equipment, Other (please specify)
                            </li>
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>
                                <b>Currency:</b> For workshops in Germany, use currency type – Euro; For workshops in
                                India,
                                use currency type – INR
                            </li>
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>Kindly refer to
                                <a href="https://www.igstc.org/home/open_call" target="_blank"> call text</a> for more
                                guidelines
                            </li>
                        </ul>
                    </div>
                </div>

