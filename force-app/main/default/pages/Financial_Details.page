                <div class="card-footer" ng-if="!proposalStage">
                    <button type="button" class="blue-btn float-end me-4" ng-click="saveLineItems('next')">Save and Next
                        <i class="fa-solid fa-arrow-right ms-3"></i>
                    </button>
                    <!-- <button type="button" class="blue-btn float-end me-2"
                        style="padding: 8px 20px !important;font-size: 16px !important;"
                        ng-click="saveLineItems('partial')">Save As Draft</button> -->
                    <button class="btn btn-secondary float-end me-2"
                        style="padding: 8px 20px !important;font-size: 16px !important;"
                        ng-click="redirectPageURL('Participants')" type="button">
                        <i class="fa-solid fa-arrow-left me-2"></i>Back</button>

