                <!-- ===== ACCORDION EXPENSES ===== -->
                <div class="row mt-3 mx-5" ng-repeat="applicnt in expenseAllList">

                    <div class="accordion modern-accordion" id="accordionPanelsStayOpenExample{{$index}}">

                        <div class="accordion-item modern-accordion-item">

                            <div class="accordion-header" id="panelsStayOpen-heading{{$index}}">
                                <button class="accordion-button modern-accordion-btn" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#panelsStayOpencollapse{{$index}}"
                                    aria-expanded="true">

                                    <h5 class="mb-0 fw-semibold color-theme">
                                        {{applicnt.Name}}
                                    </h5>

                                </button>
                            </div>

                            <div id="panelsStayOpencollapse{{$index}}" class="accordion-collapse collapse show mb-3">

                                <div class="table-card">

                                    <table class="table table-modern">
                                        <thead>
                                            <tr>
                                                <th>Description
                                                    <span class="text-danger">*</span>
                                                </th>
                                                <th>Currency Type</th>
                                                <th>Unit Cost</th>
                                                <th>Number</th>
                                                <th>Total
                                                    <span class="text-danger">*</span>
                                                </th>
                                                <th ng-hide="proposalStage" class="text-center">
                                                    <button class="btn-add" ng-click="addExpense($index)">
                                                        <i class="fas fa-plus"></i>
                                                    </button>
                                                </th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            <tr ng-repeat="lineItem in applicnt.Expense_Line_Items__r">

                                                <td>
                                                    <input type="text" class="form-control modern-input"
                                                        ng-model="lineItem.Description__c"
                                                        ng-disabled="proposalStage" />
                                                </td>

                                                <td>
                                                    <!-- <select class="form-control modern-input"
                                                        ng-model="lineItem.Currency_Type2__c" ng-disabled="true">
                                                        <option ng-repeat="staff in currencyType2" value="{{staff}}">{{staff}}</option>
                                                    </select> -->
                                                    <select class="form-control modern-input"
                                                            ng-model="lineItem.Currency_Type2__c"
                                                            ng-options="currency for currency in currencyType2"
                                                            ng-disabled="true">
                                                    </select>

                                                </td>

                                                <!-- <td>
                                                    <input type="text" class="form-control modern-input"
                                                        ng-model="lineItem.Unit_Price__c" ng-disabled="proposalStage" />
                                                </td>

                                                <td>
                                                    <input type="text" class="form-control modern-input"
                                                        ng-model="lineItem.Multiplier__c" ng-disabled="proposalStage" />
                                                </td>

                                                <td>
                                                    <input type="text" class="form-control modern-input"
                                                        ng-model="lineItem.Total_Expense__c"
                                                        ng-keyup="calculateTotalOfTotal()"
                                                        ng-change="calculateTotalOfTotal()"
                                                        ng-keypress="calculateTotalOfTotal()"
                                                        ng-disabled="proposalStage" />
                                                </td> -->
                                                <td>
                                                    <input type="number" class="form-control modern-input"
                                                        ng-model="lineItem.Unit_Price__c"
                                                        ng-change="calculateTotalOfTotal()"
                                                        ng-disabled="proposalStage" />
                                                </td>

                                                <td>
                                                    <input type="number" class="form-control modern-input"
                                                        ng-model="lineItem.Multiplier__c"
                                                        ng-change="calculateTotalOfTotal()"
                                                        ng-disabled="proposalStage" />
                                                </td>

                                                <td>
                                                    <input type="text" class="form-control modern-input"
                                                        ng-value="(lineItem.Unit_Price__c || 0) * (lineItem.Multiplier__c || 0)"
                                                        readonly="readonly" />
                                                </td>

                                                <td ng-hide="proposalStage" class="text-center">
                                                    <button class="btn-remove"
                                                        ng-click="deleteExpense($parent.$index,$index)">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </td>

                                            </tr>
                                        </tbody>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>


                <!-- ===== TOTAL SUMMARY ===== -->
                <div class="row mt-5 mx-5">
                    <div class="summary-card">

                        <table class="table table-modern mb-0">
                            <thead>
                                <tr>
                                    <th style="width:25%">Total</th>
                                    <th style="width:25%"></th>
                                    <th style="width:25%"></th>
                                    <th style="width:25%">Total</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr>
                                    <td>Total funding requested from IGSTC</td>
                                    <td></td>
                                    <td></td>
                                    <td>
                                        <input type="text" class="form-control modern-input" ng-model="IGSTCFunding"
                                            ng-disabled="true" />
                                    </td>
                                </tr>

                                <tr>
                                    <td>Funding from other sources / own contribution</td>
                                    <td></td>
                                    <td></td>
                                    <td>
                                        <input type="text" class="form-control modern-input" ng-model="OwnFunding"
                                            ng-disabled="proposalStage" />
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                    </div>
                </div>

