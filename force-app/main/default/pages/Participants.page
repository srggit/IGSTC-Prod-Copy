<apex:page sidebar="false" showHeader="false" standardStylesheets="false" controller="WorkshopController2">
    <html>
    <div ng-controller="participant_ctrl">

        <style>
            .participant-card {
                background: #ffffff;
                border-radius: 14px;
                padding: 20px;
                box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
                border: 1px solid #eef0f4;
            }

            .participant-badge {
                display: inline-block;
                background: #eef2ff !important;
                color: #3b5bdb !important;
                padding: 8px 22px !important;
                border-radius: 999px;
                font-weight: 600;
                font-size: 14px;
                letter-spacing: 0.3px;
            }

            .participant-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 15px;
            }

            .table-modern {
                border-collapse: separate;
                border-spacing: 0 10px;
            }

            .table-modern thead th {
                background: #f5f7fb;
                border: none !important;
                font-weight: 600;
            }

            .table-modern tbody tr {
                background: #ffffff;
                box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
            }

            .modern-input {
                border-radius: 8px !important;
                border: 1px solid #dfe3eb !important;
            }

            .modern-input:focus {
                border-color: #4c6ef5 !important;
                box-shadow: 0 0 0 2px rgba(76, 110, 245, .12) !important;
            }

            .btn-add {
                background: #4c6ef5;
                border: none;
                color: white;
                width: 34px;
                height: 34px;
                border-radius: 50%;
            }

            .btn-remove {
                background: #ffe3e3;
                border: none;
                color: #e03131;
                width: 32px;
                height: 32px;
                border-radius: 50%;
            }

            .modern-footer {
                background: transparent;
                border-top: none;
            }
        </style>

        <head>
            <script>
                var userId = '{!$CurrentPage.parameters.id}';
            </script>
            <apex:stylesheet value="{!$Resource.ApplicantPortalCSS}" />
        </head>

        <body>

            <div class="container mt-5">
                <div class="row mx-5">
                    <div class="col-md-12">
                        <div class="tab-link" ng-show="proposalStage">
                            <div class="progress">
                                <div class="progress-success w-100"></div>
                            </div>
                            <ul>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Coordinators_Page')">
                                        <div class="icon-circle">
                                            <i class="fab fa-wpforms"></i>
                                        </div>
                                        <span>Co-ordinators Detail</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('BasicDetails_Page')">
                                        <div class="icon-circle">
                                            <i class="fa-regular fa-building-o"></i>
                                        </div>
                                        <span>Basic Details</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Proposal_Details')">
                                        <div class="icon-circle">
                                            <i class="fa-solid fa-address-book"></i>
                                        </div>
                                        <span>Proposal Details</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Participants')">
                                        <div class="icon-circle">
                                            <i class="fas fa-file-invoice"></i>
                                        </div>
                                        <span>Participants</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Financial_Details')">
                                        <div class="icon-circle">
                                            <i class="fas fa-box"></i>
                                        </div>
                                        <span>Budget Details</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Curriculum_vitae')">
                                        <div class="icon-circle">
                                            <i class="fab fa-meetup"></i>
                                        </div>
                                        <span>Curriculum vitae</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('Meeting_Theme')">
                                        <div class="icon-circle">
                                            <i class="fas fa-people-group"></i>
                                        </div>
                                        <span>Workshop Agenda</span>
                                    </a>
                                </li>
                                <li class="active pb-cursor">
                                    <a ng-click="redirectPageURL('SignatureOfCoordinators')">
                                        <div class="icon-circle">
                                            <i class="fas fa-file-signature"></i>
                                        </div>
                                        <span>Signature</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div class="tab-link" ng-hide="proposalStage">
                            <div class="progress">
                                <div class="progress-success wp-5"></div>
                            </div>
                            <ul>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fab fa-wpforms"></i>
                                        </div>
                                        <span>Co-ordinators Detail</span>
                                    </a>
                                </li>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fa-regular fa-building-o"></i>
                                        </div>
                                        <span>Basic Details</span>
                                    </a>
                                </li>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fa-solid fa-address-book"></i>
                                        </div>
                                        <span>Proposal Details</span>
                                    </a>
                                </li>
                                <li class="active">
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fas fa-file-invoice"></i>
                                        </div>
                                        <span>Participants</span>
                                    </a>
                                </li>
                                <li>
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fas fa-box"></i>
                                        </div>
                                        <span>Budget Details</span>
                                    </a>
                                </li>
                                <li>
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fab fa-meetup"></i>
                                        </div>
                                        <span>Curriculum vitae</span>
                                    </a>
                                </li>
                                <li>
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fas fa-people-group"></i>
                                        </div>
                                        <span>Workshop Agenda</span>
                                    </a>
                                </li>
                                <li>
                                    <a>
                                        <div class="icon-circle">
                                            <i class="fas fa-file-signature"></i>
                                        </div>
                                        <span>Signature</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="row mt-5 mx-5">
                    <div class="col-md-12 alert bg-color-list" role="alert">
                        <ul class="font-if">
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>IGSTC supports participants with an
                                active role in the workshop. Participant should be
                                a speaker in the workshop.
                            </li>
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>PAN-India/Germany presence of
                                participants is necessary.
                            </li>
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>The overall number of invited
                                participants should be 30 (appx.). Students and young researchers
                                from the hosting institution may attend the
                                <br />&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; workshop programme.
                            </li>
                            <li>
                                <i class="fa-solid fa-circle text-success me-3"></i>Click on Save as Draft to regularly
                                save the data.
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- NEW UI CODE -->
                <!-- ===== PARTICIPANTS SECTION ===== -->
                <div class="row mt-3 mx-5">

                    <!-- ================= INDIAN PARTICIPANTS ================= -->
                    <div class="participant-card mb-4">

                        <!-- <div class="participant-header">
                            <h5 class="mb-0">{{IndianParticipant}}</h5>
                            <span class="badge bg-light text-dark">Participants</span>
                        </div> -->

                        <div class="text-center mb-3">
                            <span class="badge participant-badge">{{IndianParticipant}}</span>
                        </div>

                        <table class="table table-modern mt-3">
                            <thead>
                                <tr>
                                    <th style="width:5%;">Sr.No</th>
                                    <th style="width:15%;">Name
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:20%;">Position/Designation
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:18%;">Organisation
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:15%;">E-Mail
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:13%;">Phone</th>
                                    <th style="width:14%;">Speaker?
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:3%;" ng-hide="proposalStage">
                                        <button class="btn-add" ng-click="addParticipant('india')">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr ng-repeat="participant in indianList">
                                    <td>{{$index+1}}</td>

                                    <td>
                                        <input type="text" class="form-control modern-input" ng-model="participant.Name"
                                            ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <input type="text" class="form-control modern-input"
                                            ng-model="participant.Affiliation__c" ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <input type="text" class="form-control modern-input"
                                            ng-model="participant.Organisation_Institute__c"
                                            ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <input type="email" class="form-control modern-input"
                                            ng-model="participant.Email__c" ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <input type="text" class="form-control modern-input"
                                            ng-model="participant.Phone__c" ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <select class="form-control modern-input"
                                            ng-model="participant.Whether_Participant_is_presenting__c"
                                            ng-disabled="proposalStage">
                                            <option ng-repeat="staff in participatingWorkshop">{{staff}}</option>
                                        </select>
                                    </td>

                                    <td ng-hide="proposalStage">
                                        <button class="btn-remove" ng-click="removeParticipant($index,'indian')">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- ================= GERMAN PARTICIPANTS ================= -->
                    <div class="participant-card mb-4">

                        <!-- <div class="participant-header">
                            <h5 class="mb-0">{{GermanParticipant}}</h5>
                            <span class="badge bg-light text-dark">Participants</span>
                        </div> -->

                        <div class="text-center mb-3">
                            <span class="badge participant-badge">{{GermanParticipant}}</span>
                        </div>

                        <table class="table table-modern mt-3">
                            <thead>
                                <tr>
                                    <th style="width:5%;">Sr.No</th>
                                    <th style="width:15%;">Name
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:20%;">Position/Designation
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:18%;">Organisation
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:15%;">E-Mail
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:13%;">Phone</th>
                                    <th style="width:14%;">Speaker?
                                        <span style="color:red">*</span>
                                    </th>
                                    <th style="width:3%;" ng-hide="proposalStage">
                                        <button class="btn-add" ng-click="addParticipant('german')">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr ng-repeat="participant2 in germanList">
                                    <td>{{$index+1}}</td>

                                    <td>
                                        <input type="text" class="form-control modern-input"
                                            ng-model="participant2.Name" ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <input type="text" class="form-control modern-input"
                                            ng-model="participant2.Affiliation__c" ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <input type="text" class="form-control modern-input"
                                            ng-model="participant2.Organisation_Institute__c"
                                            ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <input type="email" class="form-control modern-input"
                                            ng-model="participant2.Email__c" ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <input type="text" class="form-control modern-input"
                                            ng-model="participant2.Phone__c" ng-disabled="proposalStage" />
                                    </td>

                                    <td>
                                        <select class="form-control modern-input"
                                            ng-model="participant2.Whether_Participant_is_presenting__c"
                                            ng-disabled="proposalStage">
                                            <option ng-repeat="staff in participatingWorkshop">{{staff}}</option>
                                        </select>
                                    </td>

                                    <td ng-hide="proposalStage">
                                        <button class="btn-remove" ng-click="removeParticipant2($index,'german')">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- ================= FOOTER BUTTONS ================= -->
                    <!-- <div class="card-footer modern-footer mb-5 mt-5" ng-if="!proposalStage">

                        <button type="button" class="btn btn-primary float-end me-4" ng-click="submitDetails('next')">
                            Save and Next
                            <i class="fa-solid fa-arrow-right ms-2"></i>
                        </button>

                        <button type="button" class="btn btn-outline-primary float-end me-2"
                            ng-click="submitDetails('partial')">
                            Save As Draft
                        </button>

                        <button class="btn btn-secondary float-end me-2" ng-click="redirectPageURL('Proposal_Details')"
                            type="button">
                            <i class="fa-solid fa-arrow-left me-2"></i>Back
                        </button>

                    </div> -->

                    <!-- ================= FOOTER BUTTONS ================= -->
                    <div class="card-footer mb-5 mt-4 d-flex justify-content-end gap-2 flex-wrap"
                        ng-if="!proposalStage">

                        <button class="btn btn-secondary"
                            style="padding: 8px 20px !important;font-size: 16px !important;"
                            ng-click="redirectPageURL('Proposal_Details')" type="button">
                            <i class="fa-solid fa-arrow-left me-2"></i>
                            Back
                        </button>

                        <!-- <button type="button" class="blue-btn"
                            style="padding: 8px 20px !important;font-size: 16px !important;"
                            ng-click="submitDetails('partial')">
                            Save As Draft
                        </button> -->

                        <button type="button" class="blue-btn" ng-click="submitDetails('next')">
                            Save and Next
                            <i class="fa-solid fa-arrow-right ms-3"></i>
                        </button>

                    </div>


                </div>

            </div>
        </body>
    </div>

    </html>
</apex:page>

