                                            <li><div class="list-item">IV.<span>Undertaking format towards acceptance of Grant conditions and signing of Agreement <a href="{!$Resource.Undertaking_Format_of_Grant_Acceptance}" download="Undertaking_Format_of_Grant_Acceptance.docx">[Download]</a></span></div></li>
                                        </ul>
                                    </div>
                                    
                                    <div class="stage-subsection">
                                        <div class="stage-heading">2nd Stage Proposal Submission</div>
                                        <ul class="aligned-list">
                                            <li><div class="list-item"><span>I.</span><span>2nd Stage Project Proposal <a href="{!$Resource.Second_Stage_Project_Proposal}" download="Second_Stage_Project_Proposal.docx">[Download]</a></span></div></li>
                                            <li><div class="list-item"><span>II.</span><span>Letter of Consent</span></div></li>
