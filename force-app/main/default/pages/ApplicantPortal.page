            /* Loader CSS */
            .loader {
                height: 60px;
                aspect-ratio: 2;
                border-bottom: 3px solid #0000;
                background:
                    linear-gradient(90deg, white 50%, transparent 0) -25% 100%/50% 3px repeat-x border-box;
                position: relative;
                animation: l3-0 .75s linear infinite;
            }

            .loader:before {
                content: "";
                position: absolute;
                inset: auto 42.5% 0;
                aspect-ratio: 1;
                border-radius: 50%;
                background: #4b0082;
                animation: l3-1 .75s cubic-bezier(0, 900, 1, 900) infinite;
            }

            .disabled-btn {
                background-color: #ccc;
                pointer-events: none;
                cursor: not-allowed;
                opacity: 0.6;
            }

            @keyframes l3-0 {
                to {
                    background-position: -125% 100%
                }
            }

            @keyframes l3-1 {

                0%,
                2% {
                    bottom: 0%
                }

                98%,
                to {
                    bottom: .1%
                }
            }

